DEEPSEEK_API_KEY=your_deepseek_api_key

# ========== PostgreSQL ==========
# 本地直连（不用 Docker Compose 时）示例：
# DATABASE_URL=postgresql://postgres:password@localhost/astra
#
# Docker Compose（本仓库 docker-compose.yml）：可省略 DATABASE_URL，默认连容器名 postgres。
# 若改 POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB，请同步写 DATABASE_URL，例如：
# DATABASE_URL=postgresql://astra:你的密码@postgres:5432/astra
#
# Render 等托管：由平台注入 DATABASE_URL（postgres:// 会在应用内转为 postgresql://）
DATABASE_URL=

# Compose 内 Postgres 账号（与上面 DATABASE_URL 一致时可不手写 DATABASE_URL）
POSTGRES_USER=astra
POSTGRES_PASSWORD=astra
POSTGRES_DB=astra

# 首次部署建表：true 一次后改回 false
INIT_DB=false

# Chat 防刷
# CHAT_ALLOWED_WECHAT_IDS=fss_33

